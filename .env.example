# ============================================================
# THETA Teams — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha com seus valores.
# NUNCA commite o .env.local no Git.
# ============================================================

# ---- Frontend (Vite) ----
# Encontre em: Supabase → Project Settings → API

# URL do seu projeto Supabase
VITE_SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co

# Chave pública (anon / public) — segura para o frontend
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ---- Backend (FastAPI) ----
# Configure estas no painel do Render (Environment Variables)
# ou em um arquivo .env na pasta /backend

# URL do banco de dados PostgreSQL do Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.XXXXXXXXXXXX.supabase.co:5432/postgres

# JWT Secret para validar tokens do Supabase
# Encontre em: Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# URL base do Supabase (sem trailing slash)
SUPABASE_URL=https://XXXXXXXXXXXX.supabase.co

# Service Role Key — NUNCA exponha no frontend!
# Encontre em: Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
